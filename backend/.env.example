# ── Backend (Render) ──────────────────────────────────────────────────────────
# Required
DATABASE_URL=postgresql://user:password@host/dbname
ENVIRONMENT=production
AUTH_PROVIDER=supabase

# Auth — choose one
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/rest/v1/  # actually: https://YOUR_PROJECT.supabase.co/auth/v1/jwks
# FIREBASE_PROJECT_ID=your-firebase-project-id

# CORS — your Vercel frontend URL (comma-separated if multiple)
CORS_ORIGINS=https://your-app.vercel.app

# AI Providers — set at least one (all have free tiers)
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# Optional tuning
WORKERS=1
ADVISOR_RATE_LIMIT=10/minute
LLM_CACHE_TTL_SECONDS=3600
LOG_LEVEL=info
